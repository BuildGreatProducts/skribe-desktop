{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skribe",
  "version": "0.1.0",
  "identifier": "app.skribe.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Skribe",
        "width": 1180,
        "height": 820,
        "minWidth": 860,
        "minHeight": 620,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        },
        "transparent": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "createUpdaterArtifacts": false,
    "externalBin": ["binaries/acp-sidecar"],
    "resources": ["../sidecar-acp/dist", "../references"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "A markdown writing app for people who build with AI.",
    "longDescription": "Skribe opens a local markdown folder and lets Claude Code stream editorial edits into the active document.",
    "macOS": {
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/chrisashby/skribe/releases/latest/download/latest.json"
      ]
    }
  }
}
